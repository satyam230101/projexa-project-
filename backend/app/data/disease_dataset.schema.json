{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medibot.local/schemas/disease_dataset.schema.json",
  "title": "MediBot Disease Dataset",
  "type": "object",
  "required": [
    "version",
    "updated_at",
    "diseases"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "diseases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/disease"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "title",
        "url",
        "publisher"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 200
        },
        "url": {
          "type": "string",
          "minLength": 8,
          "maxLength": 500,
          "pattern": "^https?://"
        },
        "publisher": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "disease": {
      "type": "object",
      "required": [
        "disease_id",
        "disease_name",
        "aliases",
        "common_symptoms",
        "differential_clues",
        "red_flags",
        "home_care",
        "when_to_seek_doctor",
        "emergency_signs",
        "prevention",
        "sources"
      ],
      "additionalProperties": false,
      "properties": {
        "disease_id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]{3,40}$"
        },
        "disease_name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          },
          "default": []
        },
        "common_symptoms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 160
          }
        },
        "differential_clues": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200
          }
        },
        "risk_factors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200
          },
          "default": []
        },
        "red_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200
          }
        },
        "home_care": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 220
          }
        },
        "when_to_seek_doctor": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 220
          }
        },
        "emergency_signs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 220
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 180
          },
          "default": []
        },
        "treatment_overview": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 220
          },
          "default": []
        },
        "prevention": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 220
          }
        },
        "age_group_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 220
          },
          "default": []
        },
        "severity_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "default": "medium"
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        }
      }
    }
  }
}
